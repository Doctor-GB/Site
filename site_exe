        const keys = el.getAttribute('data-i18n').split('.');
        let value = dict;
        for (const k of keys) {
          value = value?.[k];
          if (!value) break;
        }
        if (value) el.textContent = value;
      });
      localStorage.setItem('lang', lang);
      document.documentElement.lang = lang;
